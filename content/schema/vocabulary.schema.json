{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/luckliu2007/English-study/content/schema/vocabulary.schema.json",
  "title": "Vocabulary items",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "word", "phonetic", "pos", "meaning", "example", "level", "skill"],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "string", "pattern": "^v-[a-z0-9-]+$" },
      "word": { "type": "string", "minLength": 1 },
      "phonetic": { "type": "string" },
      "pos": { "type": "string", "minLength": 1 },
      "meaning": {
        "type": "string",
        "minLength": 1,
        "description": "中文释义，不应以英文单词或空格开头"
      },
      "example": { "type": "string", "minLength": 1 },
      "level": { "type": "string", "enum": ["A1", "A2", "B1", "B2", "C1", "C2"] },
      "skill": { "type": "string", "enum": ["vocab"] },
      "tags": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  }
}
